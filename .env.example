# Configuration file for Financial Document Q&A System
# Copy this to .env and fill in your values
# IMPORTANT: NEVER commit .env to Git! It contains secrets.

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI API Configuration (optional for GPT-4o-mini answer generation)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API Key — required to generate answers via GPT-4o-mini
# Get one at: https://platform.openai.com/api-keys
# Leave blank to use FREE LOCAL MODE (retrieval-only, no LLM cost)
OPENAI_API_KEY=sk-your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Model Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Use free local models instead of OpenAI?
# "true" = sentence-transformers for embeddings, no API cost (retrieval only)
# "false" = OpenAI text-embedding-3-small + GPT-4o-mini (requires OPENAI_API_KEY)
# Recommended: Set to "true" for demos, "false" for production
USE_LOCAL_MODELS=true

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Deployment
# ─────────────────────────────────────────────────────────────────────────────

# Environment: development | production
ENVIRONMENT=development

# Enable debug logging
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Storage Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ChromaDB vector database storage path
CHROMA_DB_PATH=./data/chroma_db

# Temporary PDF upload directory
UPLOAD_DIR=./data/uploads

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# FastAPI server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit port
STREAMLIT_PORT=8501

# ─────────────────────────────────────────────────────────────────────────────
# Quick Start
# ─────────────────────────────────────────────────────────────────────────────
#
# NO API KEY (free mode):
#   1. Leave OPENAI_API_KEY blank
#   2. Set USE_LOCAL_MODELS=true
#   3. Run: py -3.13 -m streamlit run app.py
#   4. Upload PDF and retrieve relevant passages (no LLM cost)
#
# WITH API KEY (full generation):
#   1. Get key from https://platform.openai.com/api-keys
#   2. Set OPENAI_API_KEY=sk-...
#   3. Set USE_LOCAL_MODELS=false
#   4. Run: py -3.13 -m streamlit run app.py
#   5. Upload PDF and get synthesised grounded answers
#
