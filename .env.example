# Configuration file for Financial Document Q&A System
# Copy this to .env and fill in your values
# IMPORTANT: NEVER commit .env to Git! It contains secrets.

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider — answer generation  (choose ONE; both are optional)
# ─────────────────────────────────────────────────────────────────────────────

# Groq — FREE and fast LLM generation (Llama 3.3 70B). RECOMMENDED.
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — alternative (GPT-4o-mini). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Provider preference: auto | groq | openai | local
# "auto" uses Groq if GROQ_API_KEY is set, else OpenAI, else local fallback.
LLM_PROVIDER=auto

# Optional model override (else: Groq=llama-3.3-70b-versatile, OpenAI=gpt-4o-mini)
# LLM_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings (retrieval) — independent of the LLM provider above
# ─────────────────────────────────────────────────────────────────────────────

# "true"  = free local sentence-transformers (MiniLM); no API cost. RECOMMENDED.
# "false" = OpenAI text-embedding-3-small (requires OPENAI_API_KEY).
# Keep "true" even with Groq: Groq has no embeddings API and MiniLM is free.
USE_LOCAL_MODELS=true

# ─────────────────────────────────────────────────────────────────────────────
# Environment & Deployment
# ─────────────────────────────────────────────────────────────────────────────

# Environment: development | production
ENVIRONMENT=development

# Enable debug logging
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Storage Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ChromaDB vector database storage path
CHROMA_DB_PATH=./data/chroma_db

# Temporary PDF upload directory
UPLOAD_DIR=./data/uploads

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# FastAPI server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit port
STREAMLIT_PORT=8501

# ─────────────────────────────────────────────────────────────────────────────
# Quick Start
# ─────────────────────────────────────────────────────────────────────────────
#
# NO API KEY (free mode):
#   1. Leave OPENAI_API_KEY blank
#   2. Set USE_LOCAL_MODELS=true
#   3. Run: py -3.13 -m streamlit run app.py
#   4. Upload PDF and retrieve relevant passages (no LLM cost)
#
# WITH API KEY (full generation):
#   1. Get key from https://platform.openai.com/api-keys
#   2. Set OPENAI_API_KEY=sk-...
#   3. Set USE_LOCAL_MODELS=false
#   4. Run: py -3.13 -m streamlit run app.py
#   5. Upload PDF and get synthesised grounded answers
#
